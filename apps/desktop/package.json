{
  "name": "@gamepulse/desktop",
  "version": "0.1.0",
  "description": "GamePulse local-first Windows comment analysis client",
  "author": "GamePulse",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dist:windows": "npm run build && node scripts/package-windows.mjs",
    "dist:windows:dir": "npm run build && node scripts/package-windows.mjs --dir"
  },
  "dependencies": {
    "@gamepulse/shared": "file:../../packages/shared",
    "@gamepulse/ui": "file:../../packages/ui",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "electron": "43.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "cn.gamepulse.desktop",
    "productName": "游脉 GamePulse",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "nsis": {
      "artifactName": "GamePulse-${version}-win-${arch}-setup.${ext}",
      "createStartMenuShortcut": true,
      "createDesktopShortcut": true,
      "shortcutName": "游脉 GamePulse",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "游脉 GamePulse"
    },
    "portable": {
      "artifactName": "GamePulse-${version}-win-${arch}-portable.${ext}"
    },
    "electronVersion": "43.0.0"
  }
}
