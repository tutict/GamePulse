{
  "name": "@gamepulse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:migrate": "tsx src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@gamepulse/shared": "file:../../packages/shared",
    "bullmq": "^5.79.2",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}
